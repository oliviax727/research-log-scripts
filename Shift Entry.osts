{"version":"0.3.0","body":"function main(workbook: ExcelScript.Workbook) {\r\n\t\r\n\tconst application = workbook.getApplication();\r\n\r\n\t// Turn off automatic calculations during the script\r\n\tapplication.setCalculationMode(ExcelScript.CalculationMode.manual);\r\n\r\n\tlet selectedSheet = workbook.getActiveWorksheet();\r\n\r\n\tshiftEntry(workbook, selectedSheet)\r\n\r\n\t// Manually calculate the file\r\n  workbook.getApplication().calculate(ExcelScript.CalculationType.full);\r\n\r\n\t// Resume automatic calculations after the script finishes\r\n\tapplication.setCalculationMode(ExcelScript.CalculationMode.automatic);\r\n}\r\n\r\nexport function shiftEntry(workbook: ExcelScript.Workbook, selectedSheet: ExcelScript.Worksheet) {\r\n\r\n\t// Shift all rows down\r\n\tselectedSheet.getRange(\"B5:G5\").insert(ExcelScript.InsertShiftDirection.down);\r\n\r\n\t// Copy formatting from row below\r\n\tselectedSheet.getRange(\"B5\").copyFrom(selectedSheet.getRange(\"B6:G6\"), ExcelScript.RangeCopyType.all, false, false);\r\n\r\n\t// Clear top row\r\n\tselectedSheet.getRange(\"B5\").clear(ExcelScript.ClearApplyTo.contents);\r\n\tselectedSheet.getRange(\"F5:G5\").clear(ExcelScript.ClearApplyTo.contents);\r\n}","description":"Creates a new blank entry","noCodeMetadata":"","parameterInfo":"{\"version\":1,\"originalParameterOrder\":[],\"parameterSchema\":{\"type\":\"object\",\"default\":{},\"x-ms-visibility\":\"internal\"},\"returnSchema\":{\"type\":\"object\",\"properties\":{}},\"signature\":{\"comment\":\"\",\"parameters\":[{\"name\":\"workbook\",\"comment\":\"\"}]}}","apiInfo":"{\"variant\":\"synchronous\",\"variantVersion\":2}"}