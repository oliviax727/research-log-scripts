{"version":"0.3.0","body":"\nfunction main(workbook: ExcelScript.Workbook) {\n  const application = workbook.getApplication();\n\t// Turn off automatic calculations during the script.\n\tapplication.setCalculationMode(ExcelScript.CalculationMode.manual);\n\n\tlet selectedSheet = workbook.getActiveWorksheet();\n\n\t// Add Entry\n\tshiftEntry(workbook, selectedSheet);\n\n\t// Copy date\n\tselectedSheet.getRange(\"B5\").copyFrom(selectedSheet.getRange(\"T5\"), ExcelScript.RangeCopyType.values, false, false);\n\n\t// Copy entry description\n\tselectedSheet.getRange(\"F5\").copyFrom(selectedSheet.getRange(\"J30\"), ExcelScript.RangeCopyType.values, false, false);\n\n\t// Copy hours\n\tselectedSheet.getRange(\"G5\").copyFrom(selectedSheet.getRange(\"L22\"), ExcelScript.RangeCopyType.values, false, false);\n\n\t// Clear entry description item\n\tselectedSheet.getRange(\"J31:N31\").clear(ExcelScript.ClearApplyTo.contents);\n\n\t// Manually calculate the file\n  workbook.getApplication().calculate(ExcelScript.CalculationType.full);\n\n\t// Resume automatic calculations after the script finishes\n\tapplication.setCalculationMode(ExcelScript.CalculationMode.automatic);\n}\n\nfunction shiftEntry(workbook: ExcelScript.Workbook, selectedSheet: ExcelScript.Worksheet) {\n\n\t// Shift all rows down\n\tselectedSheet.getRange(\"B5:G5\").insert(ExcelScript.InsertShiftDirection.down);\n\n\t// Copy formatting from row below\n\tselectedSheet.getRange(\"B5\").copyFrom(selectedSheet.getRange(\"B6:G6\"), ExcelScript.RangeCopyType.all, false, false);\n\n\t// Clear top row\n\tselectedSheet.getRange(\"B5\").clear(ExcelScript.ClearApplyTo.contents);\n\tselectedSheet.getRange(\"F5:G5\").clear(ExcelScript.ClearApplyTo.contents);\n}","description":"Adds a new entry","noCodeMetadata":"","parameterInfo":"{\"version\":1,\"originalParameterOrder\":[],\"parameterSchema\":{\"type\":\"object\",\"default\":{},\"x-ms-visibility\":\"internal\"},\"returnSchema\":{\"type\":\"object\",\"properties\":{}},\"signature\":{\"comment\":\"\",\"parameters\":[{\"name\":\"workbook\",\"comment\":\"\"}]}}","apiInfo":"{\"variant\":\"synchronous\",\"variantVersion\":2}"}