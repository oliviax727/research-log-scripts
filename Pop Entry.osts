{"version":"0.3.0","body":"function main(workbook: ExcelScript.Workbook) {\r\n\r\n\tconst application = workbook.getApplication();\r\n\t\r\n\t// Turn off automatic calculations during the script\r\n\tapplication.setCalculationMode(ExcelScript.CalculationMode.manual);\r\n\r\n\tlet selectedSheet = workbook.getActiveWorksheet();\r\n\r\n\t// Delete top row and shift up\r\n\tselectedSheet.getRange(\"B5:G5\").delete(ExcelScript.DeleteShiftDirection.up);\r\n\t\r\n\t// Manually calculate the file\r\n  workbook.getApplication().calculate(ExcelScript.CalculationType.full);\r\n\r\n\t// Resume automatic calculations after the script finishes\r\n\tapplication.setCalculationMode(ExcelScript.CalculationMode.automatic);\r\n}","description":"Removes the most recent entry","noCodeMetadata":"","parameterInfo":"{\"version\":1,\"originalParameterOrder\":[],\"parameterSchema\":{\"type\":\"object\",\"default\":{},\"x-ms-visibility\":\"internal\"},\"returnSchema\":{\"type\":\"object\",\"properties\":{}},\"signature\":{\"comment\":\"\",\"parameters\":[{\"name\":\"workbook\",\"comment\":\"\"}]}}","apiInfo":"{\"variant\":\"synchronous\",\"variantVersion\":2}"}